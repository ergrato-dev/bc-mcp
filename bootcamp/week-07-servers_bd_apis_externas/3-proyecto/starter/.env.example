# Variables de entorno para el proyecto Library Manager
# Copia este archivo: cp .env.example .env
# Luego rellena los valores reales en .env

# Base de datos SQLite — ruta dentro del contenedor
DB_PATH=./data/library.db

# Logging
LOG_LEVEL=INFO

# Open Library API — sin API key, es publica
OPENLIBRARY_URL=https://openlibrary.org/search.json

# Limite de resultados en busquedas
MAX_SEARCH_RESULTS=10

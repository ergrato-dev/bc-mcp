# Variables de entorno — MCP Library System
# Copia este archivo a .env y rellena los valores reales

# ============================================================
# OBLIGATORIO — Anthropic API Key
# ============================================================
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ============================================================
# Servidor MCP
# ============================================================
# Ruta a la base de datos SQLite dentro del contenedor Docker
DB_PATH=/data/library.db

# URL base de OpenLibrary API (no necesita cambio normalmente)
OPENLIBRARY_URL=https://openlibrary.org

# Máximo de resultados en búsquedas
MAX_SEARCH_RESULTS=20

# ============================================================
# Cliente MCP
# ============================================================
# URL del servidor MCP (nombre del servicio Docker)
MCP_SERVER_URL=http://mcp-server:8000/sse

# Modelo de Claude a usar
ANTHROPIC_MODEL=claude-opus-4-5

# Máximo de iteraciones del agentic loop antes de forzar respuesta
MAX_ITERATIONS=10
